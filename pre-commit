#!/bin/sh
# .git/hooks/pre-commit
# 安裝方式：
#   cp pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -e

TIMESTAMP=$(date +"%Y-%m-%d-%H%M%S")
AUDIT_LOG=".perf-log/audit-${TIMESTAMP}.md"
PROMPT_FILE=$(mktemp)

# ── 1. 取得這次 diff 的檔案清單 ──────────────────────────────
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  echo "⚠️  沒有 staged 檔案，跳過效能審核。"
  exit 0
fi

# ── 2. 取得完整 diff 內容（供 Agent 判斷） ───────────────────
DIFF_CONTENT=$(git diff --cached --stat)

# ── 3. 取得最近的 perf log 清單 ──────────────────────────────
mkdir -p .perf-log
PERF_LOGS=$(ls -t .perf-log/*.md 2>/dev/null | grep -v "audit-" | head -20 || echo "（無任何效能 log）")

# ── 4. 組裝 prompt ────────────────────────────────────────────
cat > "$PROMPT_FILE" << PROMPT
$(cat .claude/audit-prompt.md)

## 這次 commit 的 staged 檔案

\`\`\`
${STAGED_FILES}
\`\`\`

## git diff --stat

\`\`\`
${DIFF_CONTENT}
\`\`\`

## 現有的 .perf-log/ 記錄（最近 20 筆，不含 audit）

\`\`\`
${PERF_LOGS}
\`\`\`

## 輸出格式要求

請輸出以下格式的 Markdown，我會把它存進 ${AUDIT_LOG}：

# 效能審核報告 ${TIMESTAMP}

## 判斷結果
<!-- PASS / WARN / SKIP 三選一 -->

## 涉及的高風險改動
<!-- 條列哪些檔案或改動需要注意，若無則寫「無」 -->

## 對應的效能 log
<!-- 條列有找到哪些相關 perf-log，若無則寫「找不到對應記錄」 -->

## 建議
<!-- 具體建議，包含：要不要補跑效能檢查、建議的 commit message -->

## 模糊地帶（需人工判斷）
<!-- 列出你不確定是否需要效能驗證的部分，讓開發者決定 -->
PROMPT

# ── 5. 呼叫 Claude Code 執行審核 ─────────────────────────────
echo ""
echo "🔍 正在執行效能審核 audit..."
echo ""

AUDIT_RESULT=$(claude --print < "$PROMPT_FILE" 2>/dev/null)
rm -f "$PROMPT_FILE"

# ── 6. 把報告寫進 .perf-log/ ─────────────────────────────────
echo "$AUDIT_RESULT" > "$AUDIT_LOG"
echo ""
echo "📄 審核報告已存入：${AUDIT_LOG}"
echo ""

# ── 7. 印出摘要給開發者看 ────────────────────────────────────
echo "════════════════════════════════════════"
echo "$AUDIT_RESULT"
echo "════════════════════════════════════════"
echo ""

# ── 8. 根據結果決定是否阻擋 commit ───────────────────────────
RESULT_LINE=$(echo "$AUDIT_RESULT" | grep "## 判斷結果" -A1 | tail -1 | tr -d ' ')

if echo "$RESULT_LINE" | grep -q "WARN"; then
  echo "⚠️  審核結果為 WARN：有改動可能需要效能驗證但找不到對應記錄。"
  echo ""
  echo "選項："
  echo "  1) 繼續 commit（我知道風險）"
  echo "  2) 中止 commit（我要先補跑效能檢查）"
  echo ""
  printf "請選擇 [1/2]（預設 1）： "

  # 嘗試從 /dev/tty 讀取；若為非互動環境（CI、Claude Code）則走預設（繼續）
  CHOICE=""
  if [ -t 0 ]; then
    read CHOICE
  elif 2>/dev/null </dev/tty true; then
    exec < /dev/tty
    read CHOICE
  else
    echo "（非互動環境，自動選擇繼續 [1]）"
  fi

  if [ "$CHOICE" = "2" ]; then
    echo ""
    echo "✋ Commit 已中止。請先用 chrome-devtools-mcp 跑效能檢查，再重新 commit。"
    echo "   提示：把 audit 報告貼給 Claude Code，請它執行效能檢查。"
    echo ""
    exit 1
  fi
fi

# PASS 或選擇繼續 → 把 audit log 加進這次 commit
git add "$AUDIT_LOG" 2>/dev/null || true

echo "✅ 審核完成，繼續 commit。"
echo ""
exit 0
