# Copy to .env.local and fill in real values. Never commit real secrets here.

# --- Database ---
MONGODB_URI=
# Only needed if the DB connection requires a client certificate (e.g. Atlas mTLS)
MONGODB_CERT_BASE64=

# --- Auth (Auth.js v5) ---
# Required: signs/encrypts session, JWT, and CSRF tokens
AUTH_SECRET=
# Google login (read implicitly by next-auth's Google provider)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CLIENT_SECRET=

# --- AWS S3 (uploads: presign route) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Optional: public CDN URL for uploaded media; falls back to raw S3 URL if unset
CLOUDFRONT_URL=

# --- CloudFront signed cookies (private media read-token route) ---
CLOUDFRONT_MEDIA_URL=
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_COOKIE_DOMAIN=

# --- Video transcoding ---
MEDIACONVERT_WEBHOOK_SECRET=

# --- Audio recording / transcription ---
# 本地測試開啟錄音／轉錄功能；Vercel 不設定此變數 = 功能關閉
NEXT_PUBLIC_FEATURE_AUDIO=
OPENAI_API_KEY=
